{
  "routing_key": "${PD_ROUTING_KEY}",
  "event_action": "trigger",
  "dedup_key": "voodu-{{scope}}-{{name}}-{{release_id}}",
  "payload": {
    "summary": "voodu rollout failed: {{scope}}/{{name}}",
    "source": "{{scope}}/{{name}}",
    "severity": "error",
    "component": "{{name}}",
    "group": "{{scope}}",
    "class": "deploy",
    "custom_details": {
      "release_id": "{{release_id}}",
      "image": "{{image}}",
      "started_at": "{{started_at}}",
      "completed_at": "{{completed_at}}",
      "error": "{{error}}"
    }
  }
}
