app "clowk-vd" "docs" {
  host = "voodu-lp.lvh.me"
  replicas = 2
  command = ["bunx", "serve", "/app/out", "-l", "80"]

  build {
    args = {
      NODE_VERSION = "24-alpine"
    }
  }

  tls {
    email = "ops@voodu.clowk.in"
  }

  resources {
    limits {
      cpu = "0.5"
      memory = "100Mi"
    }
  }
}